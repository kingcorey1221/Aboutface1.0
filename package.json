{
  "name": "about-face",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "android:open": "start android",
    "android:build": "cd android && gradlew assembleDebug",
    "android:build:windows": "cd android && set \"JAVA_HOME=C:\\Program Files\\Android\\Android Studio\\jbr\" && set \"PATH=C:\\Program Files\\Android\\Android Studio\\jbr\\bin;%PATH%\" && gradlew assembleDebug",
    "neural:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-faster-liveportrait.ps1",
    "neural:api": "powershell -ExecutionPolicy Bypass -File scripts/run-faster-liveportrait-api.ps1",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.22",
    "@vitejs/plugin-react": "^4.3.4",
    "delaunator": "^5.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
